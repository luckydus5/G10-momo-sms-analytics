# Copy to .env and adjust values for your local environment.

# SQLite database location (relative to repo root)
DATABASE_URL=sqlite:///data/db.sqlite3

# Path to the raw MoMo SMS XML export
MOMO_XML_PATH=data/raw/momo.xml

# Where the dashboard JSON aggregate is written
DASHBOARD_JSON_PATH=data/processed/dashboard.json

# ETL log file
ETL_LOG_PATH=data/logs/etl.log

# Optional: FastAPI server settings (only used if running the bonus API)
API_HOST=127.0.0.1
API_PORT=8000
