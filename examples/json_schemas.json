  "sql_to_json_mapping": {
    "_description": "How each SQL column in TRANSACTIONS maps to its JSON field and type",
    "transactions": {
      "transaction_id": {
        "json_field": "transaction_id",
        "sql_type": "INT UNSIGNED",
        "json_type": "number"
      },
      "financial_tx_id": {
        "json_field": "financial_tx_id",
        "sql_type": "VARCHAR(30)",
        "json_type": "string|null — NULL for BANK_DEPOSIT and some OUTGOING_TRANSFER records"
      },
      "category_id": {
        "json_field": "category.category_id",
        "sql_type": "INT UNSIGNED",
        "json_type": "number (nested object in full response)"
      },
      "counterparty_id": {
        "json_field": "counterparty.user_id",
        "sql_type": "INT UNSIGNED",
        "json_type": "number|null (nested object in full response)"
      },
      "amount": {
        "json_field": "amount",
        "sql_type": "DECIMAL(15,2)",
        "json_type": "number"
      },
      "currency": {
        "json_field": "currency",
        "sql_type": "CHAR(3)",
        "json_type": "string — always RWF"
      },
      "fee": {
        "json_field": "fee",
        "sql_type": "DECIMAL(10,2)",
        "json_type": "number — 0.00 when SMS states 'Fee was 0 RWF'"
      },
      "balance_after": {
        "json_field": "balance_after",
        "sql_type": "DECIMAL(15,2)",
        "json_type": "number|null"
      },
      "transaction_date": {
        "json_field": "transaction_date",
        "sql_type": "DATETIME",
        "json_type": "string (ISO 8601 UTC)"
      },
      "sms_date_unix": {
        "json_field": "sms_date_unix",
        "sql_type": "BIGINT",
        "json_type": "number — Unix ms from XML date attribute"
      },
      "sms_readable_date": {
        "json_field": "sms_readable_date",
        "sql_type": "VARCHAR(40)",
        "json_type": "string — readable_date from XML e.g. '10 May 2024 4:30:58 PM'"
      },
      "direction": {
        "json_field": "direction",
        "sql_type": "ENUM",
        "json_type": "string — incoming/outgoing/neutral"
      },
      "status": {
        "json_field": "status",
        "sql_type": "ENUM",
        "json_type": "string — completed/reversed/pending/failed"
      },
      "raw_sms_body": {
        "json_field": "raw_sms_body",
        "sql_type": "TEXT",
        "json_type": "string|null — omitted in list API, included in single record and full expand"
      }
    }
  }
